{
  "name": "riaf-studio",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "main": "./out/main/index.js",
  "engines": {
    "node": ">=20 <23"
  },
  "scripts": {
    "dev": "pnpm rebuild:electron && sh -c 'ulimit -n 10240 2>/dev/null || true; exec electron-vite dev'",
    "build": "tsc -b packages/shared && electron-vite build",
    "rebuild": "electron-rebuild -f -w better-sqlite3",
    "rebuild:node": "node scripts/setup-native-modules.cjs node",
    "rebuild:electron": "node scripts/setup-native-modules.cjs electron",
    "postinstall": "node scripts/setup-native-modules.cjs node",
    "package": "pnpm build && pnpm rebuild:electron && electron-forge package",
    "make": "pnpm build && pnpm rebuild:electron && electron-forge make",
    "test": "pnpm rebuild:node && vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.4.0",
    "@electron-forge/maker-dmg": "^7.4.0",
    "@electron-forge/maker-squirrel": "^7.4.0",
    "@electron-forge/maker-zip": "^7.4.0",
    "@electron/rebuild": "^3.6.0",
    "@types/node": "^22.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "electron": "^31.0.0",
    "electron-vite": "^2.3.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
